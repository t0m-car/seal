generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Secret {
  id         String   @id @default(nanoid(11))
  iv         String
  ciphertext String
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  nbOpenings Int      @default(1)

  @@index([expiresAt])
}
